---
import { withBase } from "@/lib/path";
---

<section class="relative isolate overflow-hidden bg-slate-900" data-vision-hero>
  <div class="relative isolate min-h-[100svh] overflow-hidden">
    <img
      class="absolute inset-0 h-full w-full object-cover object-[55%_48%]"
      src={withBase("/images/home-hero-forest.png")}
      alt="건강한 삶과 지속 가능한 성장을 상징하는 숲 전경 이미지"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-black/28"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(13,22,34,0.10),rgba(13,22,34,0.18)_35%,rgba(13,22,34,0.42))]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.06),rgba(0,0,0,0.20)_64%,rgba(0,0,0,0.35))]"></div>
    <div class="container-page relative flex min-h-[100svh] items-center justify-center px-5 pb-20 pt-28 text-center text-white lg:pt-32">
      <div class="max-w-6xl [text-shadow:0_4px_20px_rgba(0,0,0,0.42)]">
        <p class="mb-8 text-xs font-black tracking-[0.42em] text-emerald-100 sm:text-sm">BIOLAB VISION</p>
        <h1 class="text-[42px] font-black italic leading-[1.08] tracking-[-0.02em] text-white sm:text-[68px] lg:text-[86px]">
          We Are Real Partner<br />
          For Healthy Life
        </h1>
        <p class="mx-auto mt-10 max-w-4xl text-sm font-bold leading-8 text-white/92 sm:text-lg sm:leading-9">
          비오랩은 원료를 고르는 기준부터 제품 경험과 유통 채널까지,
          건강한 일상을 위한 신뢰의 파트너가 되겠습니다.
        </p>
      </div>
    </div>
  </div>
</section>
