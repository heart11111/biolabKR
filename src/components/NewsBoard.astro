---
import type { NewsItem } from "@/data/news";
import { withBase } from "@/lib/path";

type Props = {
  items: NewsItem[];
  categories: string[];
};

const { items, categories } = Astro.props;
---

<div class="border-t-2 border-brand-navy" data-news-board>
  <div class="grid border-b border-slate-200 bg-slate-50 sm:grid-cols-5" aria-label="뉴스 카테고리">
    {categories.map((category, index) => (
      <span
        class:list={[
          "border-b border-r border-slate-200 px-5 py-4 text-center text-sm font-extrabold transition hover:bg-white hover:text-brand-blue sm:border-b-0",
          index === 0 ? "bg-brand-navy text-white hover:bg-brand-navy hover:text-white" : "text-slate-700"
        ]}
      >
        {category}
      </span>
    ))}
  </div>

  <div class="flex flex-col gap-3 border-b border-slate-200 bg-white px-4 py-5 md:flex-row md:items-center md:justify-between">
    <p class="text-sm font-semibold text-slate-600">
      Total <span class="font-black text-brand-blue">{items.length}</span>
    </p>
    <div class="grid gap-2 sm:grid-cols-[130px_1fr_80px] md:w-[520px]">
      <select class="h-11 border border-slate-200 bg-white px-3 text-sm text-slate-600" aria-label="검색 범위" disabled>
        <option>전체</option>
        <option>제목</option>
        <option>내용</option>
        <option>작성자</option>
      </select>
      <input class="h-11 border border-slate-200 bg-white px-3 text-sm text-slate-500" type="search" placeholder="검색어를 입력하세요" disabled />
      <button class="h-11 bg-brand-navy text-sm font-bold text-white" type="button" disabled>검색</button>
    </div>
  </div>

  <div class="hidden md:block">
    <div class="grid grid-cols-[80px_120px_1fr_130px_130px_90px] border-b border-slate-200 bg-slate-100 px-4 py-4 text-center text-sm font-extrabold text-brand-navy">
      <span>No</span>
      <span>구분</span>
      <span>제목</span>
      <span>작성자</span>
      <span>작성일</span>
      <span>조회수</span>
    </div>
    {items.map((item, index) => (
      <a
        class="grid grid-cols-[80px_120px_1fr_130px_130px_90px] border-b border-slate-200 px-4 py-5 text-center text-sm text-slate-600 hover:bg-slate-50"
        href={withBase(item.href)}
      >
        <span class="font-semibold">{items.length - index}</span>
        <span class="font-bold text-brand-green">{item.category}</span>
        <span class="text-left text-base font-extrabold text-slate-900">{item.title}</span>
        <span>{item.author ?? "관리자"}</span>
        <time>{item.date}</time>
        <span>{item.views ?? "-"}</span>
      </a>
    ))}
  </div>

  <div class="divide-y divide-slate-200 md:hidden">
    {items.map((item, index) => (
      <a class="block px-4 py-5 hover:bg-slate-50" href={withBase(item.href)}>
        <div class="mb-3 flex flex-wrap items-center gap-2 text-xs font-bold">
          <span class="bg-brand-mint px-3 py-1 text-brand-green">{item.category}</span>
          <span class="text-slate-500">No. {items.length - index}</span>
          <time class="text-slate-500">{item.date}</time>
        </div>
        <h3 class="text-lg font-extrabold leading-7 text-brand-navy">{item.title}</h3>
        <p class="mt-3 text-sm leading-7 text-slate-600">{item.summary}</p>
      </a>
    ))}
  </div>

  <div class="flex justify-center gap-1 border-b border-slate-200 bg-white py-6 text-sm font-bold text-slate-600" aria-label="게시판 페이지">
    <span class="border border-slate-200 px-3 py-2 text-slate-400">이전</span>
    <span class="border border-brand-blue bg-brand-blue px-3 py-2 text-white">1</span>
    <span class="border border-slate-200 px-3 py-2 text-slate-400">다음</span>
  </div>
</div>
