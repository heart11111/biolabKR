---
import type { FAQ } from "@/data/faqs";

type Props = {
  items: FAQ[];
};

const { items } = Astro.props;
---

<div class="divide-y divide-slate-200 border-y border-slate-200">
  {items.map((item) => (
    <details class="group py-5">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-bold text-slate-900">
        {item.question}
        <span class="text-2xl text-brand-blue group-open:rotate-45">+</span>
      </summary>
      <p class="mt-4 text-sm leading-7 text-slate-600">{item.answer}</p>
    </details>
  ))}
</div>

