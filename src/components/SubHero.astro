---
import { withBase } from "@/lib/path";

type Props = {
  title: string;
  description: string;
  image?: string;
};

const { title, description, image = "/images/sub-hero.jpg" } = Astro.props;
---

<section class="relative overflow-hidden bg-brand-navy">
  <div class="absolute inset-0">
    <img class="h-full w-full object-cover opacity-35" src={withBase(image)} alt="" />
    <div class="absolute inset-0 bg-brand-navy/70"></div>
  </div>
  <div class="container-page relative flex min-h-[250px] flex-col justify-center py-16 text-white">
    <p class="mb-3 text-sm font-bold tracking-[0.24em] text-emerald-200">BIOLAB</p>
    <h1 class="text-4xl font-black [overflow-wrap:anywhere]">{title}</h1>
    <p class="mt-5 max-w-[320px] break-all text-base leading-7 text-slate-100 [overflow-wrap:anywhere] sm:max-w-2xl">{description}</p>
  </div>
</section>
