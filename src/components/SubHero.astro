---
import { withBase } from "@/lib/path";

type Props = {
  title: string;
  description: string;
  image?: string;
  imagePosition?: string;
  visualWord?: string;
  compact?: boolean;
};

const props = Astro.props;
const presets = [
  {
    match: ["원료", "기술", "연구", "품질", "핵심"],
    image: "/images/science/petri-pipette-lab.jpg",
    position: "50% 48%",
    word: "R & D"
  },
  {
    match: ["제품", "여성", "키즈", "이너", "다이어트", "아이힐"],
    image: "/images/science/clinical-capsules-doctor.jpg",
    position: "52% 48%",
    word: "PRODUCT"
  },
  {
    match: ["공지", "보도", "FAQ", "문의", "고객"],
    image: "/images/competence-global.jpg",
    position: "54% 50%",
    word: "NEWS"
  },
  {
    match: ["대표", "회사", "연혁", "파트너", "찾아오시는"],
    image: "/images/science/capsules-tablets-clinical.jpg",
    position: "52% 48%",
    word: "BIOLAB"
  }
];

const preset = presets.find((item) => item.match.some((keyword) => props.title.includes(keyword)));
const coverCopy = new Map([
  ["회사소개", "기준이 있는 제품 설계와 책임 있는 유통으로 건강한 일상의 신뢰를 만듭니다."],
  ["회사 개요", "원료, 제품, 채널을 함께 관리하며 iHEAL 브랜드의 성장을 설계합니다."],
  ["대표 인사말", "건강한 일상에 닿는 제품을 만들기 위해 원료와 품질의 기준을 지켜가겠습니다."],
  ["연혁", "제품 개발과 국내외 채널 확장을 통해 브랜드의 다음 단계를 준비합니다."],
  ["주요 파트너", "국내외 유통 네트워크와 함께 브랜드 접점을 넓혀갑니다."],
  ["찾아오시는 길", "제품, 원료, 유통 제휴 상담을 위한 비오랩의 위치와 연락처입니다."],
  ["원료/기술 소개", "특허 균주와 기능성 원료를 제품 목적에 맞춰 검증하고 설계합니다."],
  ["핵심 원료", "여성 건강, 키즈 건강, 이너케어 제품을 위한 핵심 원료 기준을 정리합니다."],
  ["연구개발", "건강기능식품과 이너케어 제품의 효능, 안정성, 사용성을 함께 검토합니다."],
  ["품질관리", "원료 선정부터 표시 기준과 유통 이력까지 단계별 관리 체계를 유지합니다."],
  ["제품소개", "여성과 아이의 일상에 맞춘 iHEAL 제품 포트폴리오를 소개합니다."],
  ["여성 건강", "여성의 생활 리듬과 섭취 편의를 고려한 유산균 라인입니다."],
  ["키즈 건강", "성장기 아이의 영양과 섭취 경험을 고려한 키즈 건강 라인입니다."],
  ["이너케어", "데일리 루틴에 맞춘 이너 뷰티와 Y존 케어 제품군입니다."],
  ["다이어트", "특허 균주와 기능성 원료를 바탕으로 체지방 관리 루틴을 제안합니다."],
  ["제품 선택 가이드", "제품 목적과 원료 기준을 한눈에 비교할 수 있도록 정리했습니다."],
  ["고객지원", "제품, 입점, 제휴 문의와 브랜드 소식을 정확하게 안내합니다."],
  ["공지사항 / 보도자료", "비오랩과 iHEAL 브랜드의 주요 소식을 기업 게시판 형식으로 전합니다."],
  ["문의하기", "제품, 원료, 유통 제휴 상담을 위한 공식 문의 창구입니다."],
  ["FAQ", "제품과 제휴 문의에서 자주 확인하는 내용을 정리했습니다."]
]);

const {
  title,
  description: propDescription,
  image = preset?.image ?? "/images/studio/studio-iheal-lineup-hero.jpg",
  imagePosition = preset?.position ?? "58% 48%",
  visualWord = preset?.word ?? "BIOLAB",
  compact = false
} = props;

const description = coverCopy.get(title) ?? propDescription;
---

{compact ? (
  <section class="border-b border-slate-200 bg-white">
    <div class="container-page py-16 lg:py-20">
      <p class="mb-5 text-sm font-black tracking-[0.34em] text-brand-green">BIOLAB</p>
      <h1 class="text-4xl font-black leading-tight text-brand-navy [overflow-wrap:anywhere] md:text-5xl">{title}</h1>
      <p class="mt-5 max-w-3xl text-base font-semibold leading-8 text-slate-700 [overflow-wrap:anywhere] md:text-lg">
        {description}
      </p>
      <div class="mt-8 h-[3px] w-16 bg-brand-blue" aria-hidden="true"></div>
    </div>
  </section>
) : (
<section class="relative isolate overflow-hidden bg-[#202a39]">
  <div class="absolute inset-0">
    <img
      class="h-full w-full scale-[1.04] object-cover saturate-[0.9]"
      src={withBase(image)}
      alt=""
      style={`object-position: ${imagePosition};`}
    />
    <div class="absolute inset-0 bg-[#1f2938]/54"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_45%,rgba(255,255,255,0.18),transparent_32%),linear-gradient(90deg,rgba(20,28,40,0.62),rgba(20,28,40,0.20)_46%,rgba(20,28,40,0.62))]"></div>
  </div>
  <div class="container-page relative flex min-h-[520px] items-center justify-center px-6 pb-20 pt-32 text-center text-white md:min-h-[600px] lg:min-h-[650px] lg:pt-36">
    <div class="max-w-5xl">
      <p class="mb-6 text-xs font-black tracking-[0.38em] text-white/68 md:text-sm">{visualWord}</p>
      <h1 class="text-5xl font-black leading-tight text-white [overflow-wrap:anywhere] md:text-6xl lg:text-7xl">{title}</h1>
      <p class="mx-auto mt-6 max-w-4xl text-lg font-bold leading-8 text-white/92 [overflow-wrap:anywhere] md:text-2xl md:leading-10">
        {description}
      </p>
    </div>
  </div>
</section>
)}
