---
import { withBase } from "@/lib/path";

type Props = {
  title: string;
  description: string;
  image?: string;
};

const { title, description, image = "/images/studio/studio-iheal-lineup-hero.jpg" } = Astro.props;
---

<section class="relative overflow-hidden border-b border-slate-200 bg-[#f6fbf9]">
  <div class="absolute inset-y-0 right-0 hidden w-[54%] lg:block">
    <img class="h-full w-full object-cover object-center" src={withBase(image)} alt="" />
    <div class="absolute inset-0 bg-gradient-to-r from-[#f6fbf9] via-[#f6fbf9]/72 to-white/10"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-white/10 via-transparent to-brand-navy/10"></div>
  </div>
  <div class="absolute left-0 top-0 h-full w-2 bg-brand-green/80" aria-hidden="true"></div>
  <div class="container-page relative grid min-h-[320px] items-center gap-8 py-14 lg:grid-cols-[0.58fr_0.42fr]">
    <div class="max-w-2xl">
      <p class="mb-5 text-sm font-black tracking-[0.32em] text-brand-green">BIOLAB</p>
      <h1 class="text-4xl font-black leading-tight text-brand-navy [overflow-wrap:anywhere] md:text-5xl">{title}</h1>
      <p class="mt-6 max-w-[640px] text-lg font-semibold leading-8 text-slate-700 [overflow-wrap:anywhere]">{description}</p>
      <div class="mt-8 h-[3px] w-16 bg-brand-blue" aria-hidden="true"></div>
    </div>
    <div class="relative block lg:hidden">
      <img class="aspect-[16/9] w-full border border-slate-200 object-cover shadow-sm" src={withBase(image)} alt="" />
    </div>
  </div>
</section>
