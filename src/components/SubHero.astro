---
import { withBase } from "@/lib/path";

type Props = {
  title: string;
  description: string;
  image?: string;
  imagePosition?: string;
  visualWord?: string;
  compact?: boolean;
};

const props = Astro.props;
const presets = [
  {
    match: ["원료", "기술", "연구", "품질", "핵심"],
    image: "/images/ingredients/ingredient-strain-culture.jpg",
    position: "62% 48%",
    word: "R & D"
  },
  {
    match: ["제품", "여성", "키즈", "이너", "다이어트", "아이힐"],
    image: "/images/studio/studio-iheal-three-products.jpg",
    position: "68% 46%",
    word: "PRODUCT"
  },
  {
    match: ["공지", "보도", "FAQ", "문의", "고객"],
    image: "/images/competence-global.jpg",
    position: "52% 50%",
    word: "NEWS"
  },
  {
    match: ["대표", "회사", "연혁", "파트너", "찾아오시는"],
    image: "/images/studio/studio-iheal-lineup-hero.jpg",
    position: "60% 45%",
    word: "BIOLAB"
  }
];

const preset = presets.find((item) => item.match.some((keyword) => props.title.includes(keyword)));
const {
  title,
  description,
  image = preset?.image ?? "/images/studio/studio-iheal-lineup-hero.jpg",
  imagePosition = preset?.position ?? "58% 48%",
  visualWord = preset?.word ?? "BIOLAB",
  compact = false
} = props;
---

{compact ? (
  <section class="border-b border-slate-200 bg-white">
    <div class="container-page py-16 lg:py-20">
      <p class="mb-5 text-sm font-black tracking-[0.34em] text-brand-green">BIOLAB</p>
      <h1 class="text-4xl font-black leading-tight text-brand-navy [overflow-wrap:anywhere] md:text-5xl">{title}</h1>
      <p class="mt-5 max-w-3xl text-base font-semibold leading-8 text-slate-700 [overflow-wrap:anywhere] md:text-lg">
        {description}
      </p>
      <div class="mt-8 h-[3px] w-16 bg-brand-blue" aria-hidden="true"></div>
    </div>
  </section>
) : (
<section class="relative isolate overflow-hidden bg-neutral-900">
  <div class="absolute inset-0">
    <img
      class="h-full w-full scale-[1.05] object-cover saturate-[1.04]"
      src={withBase(image)}
      alt=""
      style={`object-position: ${imagePosition};`}
    />
    <div class="absolute inset-0 bg-black/34"></div>
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(0,121,99,0.38),rgba(0,0,0,0.08)_48%,rgba(0,121,99,0.30))]"></div>
  </div>
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <span class="absolute left-1/2 top-1/2 hidden -translate-x-1/2 -translate-y-1/2 whitespace-nowrap text-[clamp(5rem,14vw,13rem)] font-light tracking-[0.04em] text-white/[0.11] lg:block">
      {visualWord}
    </span>
  </div>
  <div class="container-page relative flex min-h-[320px] items-center justify-center py-20 text-center text-white lg:min-h-[360px]">
    <div class="max-w-4xl [text-shadow:0_3px_16px_rgba(0,0,0,0.35)]">
      <h1 class="text-4xl font-light leading-tight [overflow-wrap:anywhere] md:text-6xl">{title}</h1>
      <p class="mx-auto mt-6 max-w-3xl text-base font-bold leading-8 text-white/95 [overflow-wrap:anywhere] md:text-lg">
        {description}
      </p>
    </div>
  </div>
</section>
)}
