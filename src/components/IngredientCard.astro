---
import type { Ingredient } from "@/data/ingredients";
import Icon from "@/components/Icon.astro";
import { withBase } from "@/lib/path";

type Props = {
  ingredient: Ingredient;
};

const { ingredient } = Astro.props;
---

<article class="group grid h-full overflow-hidden border border-slate-200 bg-white shadow-sm md:grid-cols-[0.38fr_0.62fr]" data-reveal>
  <figure class="relative min-h-[180px] overflow-hidden bg-slate-50">
    <img
      class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.04]"
      src={withBase(ingredient.image)}
      alt={ingredient.imageAlt}
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.18),rgba(53,183,121,0.12))]"></div>
  </figure>
  <div class="p-7">
    <div class="mb-5 flex h-11 w-11 items-center justify-center border border-brand-green/20 bg-brand-mint text-brand-green">
      <Icon name={ingredient.icon} class="h-5 w-5" />
    </div>
    <p class="mb-3 text-sm font-bold text-brand-green">{ingredient.subtitle}</p>
    <h3 class="text-xl font-extrabold text-brand-navy">{ingredient.title}</h3>
    <p class="mt-4 text-sm leading-7 text-slate-600">{ingredient.body}</p>
    <div class="mt-6 flex flex-wrap gap-2">
      {ingredient.tags.map((tag) => (
        <span class="bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">{tag}</span>
      ))}
    </div>
  </div>
</article>
