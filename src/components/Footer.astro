---
import { site } from "@/data/site";
import { withBase } from "@/lib/path";
---

<footer class="border-t border-slate-200 bg-slate-950 text-slate-300">
  <div class="container-page py-12">
    <div class="flex flex-col justify-between gap-10 lg:flex-row">
      <div>
        <a class="inline-flex bg-white px-5 py-3" href={withBase("/")} aria-label={`${site.name} 홈`}>
          <img class="h-8 w-auto" src={withBase("/images/brand/biolab-logo.png")} alt={site.englishName} />
        </a>
        <p class="mt-5 max-w-2xl text-sm leading-7 text-slate-400">{site.description}</p>
      </div>
      <nav class="grid grid-cols-2 gap-x-10 gap-y-3 text-sm sm:grid-cols-5" aria-label="푸터 메뉴">
        {site.navigation.map((item) => (
          <a class="hover:text-white" href={withBase(item.href)}>{item.label}</a>
        ))}
      </nav>
    </div>

    <div class="mt-10 border-t border-white/10 pt-8 text-sm leading-7 text-slate-400">
      <p>
        <span class="font-semibold text-slate-200">{site.name}</span>
        <span class="mx-3 text-slate-600">|</span>대표: {site.ceo}
        <span class="mx-3 text-slate-600">|</span>사업자번호: {site.registrationNumber}
      </p>
      <p>주소: {site.address}</p>
      <p>대표번호: {site.phone} <span class="mx-3 text-slate-600">|</span> 팩스: {site.fax} <span class="mx-3 text-slate-600">|</span> 이메일: {site.email}</p>
      <p class="mt-5 text-xs text-slate-500">COPYRIGHT © {site.name}. ALL RIGHTS RESERVED.</p>
    </div>
  </div>
</footer>
