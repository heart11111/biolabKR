---
import type { SubpageItem } from "@/data/subpages";
import { withBase } from "@/lib/path";

type Props = {
  items: SubpageItem[];
};

const { items } = Astro.props;
---

<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3" data-subpage-grid>
  {items.map((item) => (
    <a class="group flex min-h-[220px] flex-col border border-slate-200 bg-white p-7 shadow-sm transition hover:border-brand-blue hover:bg-slate-50 hover:shadow-corporate" href={withBase(item.href)}>
      <span class="text-xs font-black tracking-[0.22em] text-brand-green">{item.eyebrow}</span>
      <strong class="mt-5 text-2xl font-black text-brand-navy">{item.label}</strong>
      <p class="mt-4 flex-1 text-sm leading-7 text-slate-600">{item.summary}</p>
      <span class="mt-7 inline-flex text-sm font-extrabold text-brand-blue">
        자세히 보기 <span class="ml-2 transition group-hover:translate-x-1" aria-hidden="true">→</span>
      </span>
    </a>
  ))}
</div>
