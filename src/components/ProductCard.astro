---
import type { Product } from "@/data/products";
import Icon from "@/components/Icon.astro";
import { withBase } from "@/lib/path";

type Props = {
  product: Product;
};

const { product } = Astro.props;

const iconName = product.category.includes("키즈")
  ? "baby"
  : product.category.includes("이너")
    ? "droplet"
    : product.category.includes("다이어트")
      ? "scale"
      : "heartPulse";
---

<article class="group flex h-full flex-col overflow-hidden border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-corporate" data-reveal>
  <a class="relative block aspect-[4/3] overflow-hidden bg-[#f6f9fa]" href={withBase(`/products/${product.slug}/`)} aria-label={`${product.name} 상세 보기`}>
    <img
      class="absolute inset-0 h-full w-full scale-110 object-cover opacity-20 blur-md"
      src={withBase(product.image)}
      alt=""
      loading="lazy"
      decoding="async"
    />
    <img
      class="relative z-10 h-full w-full object-contain p-5 transition duration-300 group-hover:scale-[1.03]"
      src={withBase(product.image)}
      alt={product.name}
      loading="lazy"
      decoding="async"
    />
  </a>
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-4 flex items-center justify-between gap-3">
      <span class="inline-flex w-fit bg-brand-mint px-3 py-1 text-xs font-bold text-brand-green">{product.category}</span>
      <span class="flex h-10 w-10 shrink-0 items-center justify-center border border-brand-blue/20 bg-slate-50 text-brand-blue">
        <Icon name={iconName} class="h-5 w-5" />
      </span>
    </div>
    <h3 class="text-xl font-extrabold text-brand-navy">{product.name}</h3>
    <p class="mt-2 text-sm font-semibold text-slate-500">{product.englishName}</p>
    <p class="mt-4 flex-1 text-sm leading-7 text-slate-600">{product.summary}</p>
    <a class="mt-6 inline-flex text-sm font-bold text-brand-blue" href={withBase(`/products/${product.slug}/`)}>
      자세히 보기 <span class="ml-2" aria-hidden="true">→</span>
    </a>
  </div>
</article>
