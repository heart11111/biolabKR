---
import type { Product } from "@/data/products";
import Icon from "@/components/Icon.astro";
import { withBase } from "@/lib/path";

type Props = {
  product: Product;
};

const { product } = Astro.props;

const iconName = product.category.includes("키즈")
  ? "baby"
  : product.category.includes("이너")
    ? "droplet"
    : product.category.includes("다이어트")
      ? "scale"
      : "heartPulse";

const visuals: Record<string, { from: string; to: string; accent: string; label: string; word: string }> = {
  "venus-probiotics": {
    from: "#fde8ef",
    to: "#e9f7f4",
    accent: "#ef8aa6",
    label: "WOMEN BALANCE",
    word: "VENUS"
  },
  "venus-stick-probiotics": {
    from: "#fbefe0",
    to: "#eef8f4",
    accent: "#d9a46f",
    label: "STICK ROUTINE",
    word: "STICK"
  },
  "kids-lac-probiotics": {
    from: "#e5f8f7",
    to: "#fff3cf",
    accent: "#6bbdd1",
    label: "KIDS CARE",
    word: "KIDS"
  },
  "line-n-probiotics": {
    from: "#f7eaf2",
    to: "#e7f2ff",
    accent: "#a88fd8",
    label: "DIET CARE",
    word: "LINE N"
  },
  "inner-clean-v": {
    from: "#eef8f6",
    to: "#f8efe5",
    accent: "#78b8ac",
    label: "INNER CLEAN",
    word: "CLEAN"
  },
  "venus-inner-perfume": {
    from: "#fdeaf0",
    to: "#f2f7f5",
    accent: "#df8eaa",
    label: "INNER BEAUTY",
    word: "PERFUME"
  }
};

const visual = visuals[product.slug] ?? visuals["venus-probiotics"];
---

<article class="group flex h-full flex-col overflow-hidden border border-neutral-200 bg-white transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_45px_rgba(0,0,0,0.08)]" data-reveal>
  <a
    class="relative block aspect-[4/3] overflow-hidden"
    href={withBase(`/products/${product.slug}/`)}
    aria-label={`${product.name} 상세 보기`}
    style={`--pv-from:${visual.from};--pv-to:${visual.to};--pv-accent:${visual.accent};`}
  >
    <div class="absolute inset-0 bg-[linear-gradient(135deg,var(--pv-from),var(--pv-to))]"></div>
    <div class="absolute -right-20 -top-20 h-56 w-56 rounded-full bg-white/45 blur-2xl"></div>
    <div class="absolute -bottom-24 left-8 h-52 w-52 rounded-full bg-white/35 blur-2xl"></div>
    <div class="absolute left-7 top-7 z-10">
      <span class="text-[11px] font-black tracking-[0.28em] text-neutral-900/55">{visual.label}</span>
      <strong class="mt-4 block max-w-[230px] text-2xl font-black leading-tight text-neutral-900">{product.name.replace("아이힐 ", "")}</strong>
      <span class="mt-4 block h-[3px] w-12 bg-[var(--pv-accent)]"></span>
    </div>
    <span class="absolute bottom-4 left-6 z-0 text-[4.7rem] font-black leading-none tracking-[-0.03em] text-white/52">
      {visual.word}
    </span>
    <div class="absolute bottom-7 right-7 z-10 flex h-[62%] w-[44%] items-center justify-center">
      <img
        class="max-h-full max-w-full object-contain drop-shadow-[0_22px_26px_rgba(15,23,42,0.16)] mix-blend-multiply transition duration-500 group-hover:scale-[1.06]"
        src={withBase(product.image)}
        alt={product.name}
        loading="lazy"
        decoding="async"
      />
    </div>
  </a>
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-4 flex items-center justify-between gap-3">
      <span class="inline-flex w-fit bg-brand-mint px-3 py-1 text-xs font-bold text-brand-green">{product.category}</span>
      <span class="flex h-10 w-10 shrink-0 items-center justify-center border border-brand-blue/20 bg-slate-50 text-brand-blue">
        <Icon name={iconName} class="h-5 w-5" />
      </span>
    </div>
    <h3 class="text-xl font-extrabold text-neutral-900">{product.name}</h3>
    <p class="mt-2 text-sm font-semibold text-slate-500">{product.englishName}</p>
    <p class="mt-4 flex-1 text-sm leading-7 text-slate-600">{product.summary}</p>
    <a class="mt-6 inline-flex text-sm font-bold text-brand-green" href={withBase(`/products/${product.slug}/`)}>
      자세히 보기 <span class="ml-2" aria-hidden="true">→</span>
    </a>
  </div>
</article>
