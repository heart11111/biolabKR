---
import type { Product } from "@/data/products";
import { withBase } from "@/lib/path";

type Props = {
  product: Product;
};

const { product } = Astro.props;
---

<article class="group flex h-full flex-col overflow-hidden border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-corporate">
  <a href={withBase(`/products/${product.slug}/`)} aria-label={`${product.name} 상세 보기`}>
    <img class="h-56 w-full object-cover" src={withBase(product.image)} alt={product.name} />
  </a>
  <div class="flex flex-1 flex-col p-6">
    <span class="mb-3 inline-flex w-fit bg-brand-mint px-3 py-1 text-xs font-bold text-brand-green">{product.category}</span>
    <h3 class="text-xl font-extrabold text-brand-navy">{product.name}</h3>
    <p class="mt-2 text-sm font-semibold text-slate-500">{product.englishName}</p>
    <p class="mt-4 flex-1 text-sm leading-7 text-slate-600">{product.summary}</p>
    <a class="mt-6 inline-flex text-sm font-bold text-brand-blue" href={withBase(`/products/${product.slug}/`)}>
      자세히 보기 <span class="ml-2" aria-hidden="true">→</span>
    </a>
  </div>
</article>

