---
import { withBase } from "@/lib/path";

type SectionLink = {
  label: string;
  href: string;
  description: string;
};

type Props = {
  title?: string;
  sections: SectionLink[];
};

const { title = "이 페이지에서 확인할 내용", sections } = Astro.props;
const resolveHref = (href: string) => (href.startsWith("#") ? href : withBase(href));
---

<section class="border-y border-slate-200 bg-slate-50" data-page-section-nav>
  <div class="container-page grid gap-6 py-8 lg:grid-cols-[250px_1fr] lg:items-start">
    <div>
      <p class="text-xs font-black tracking-[0.22em] text-brand-green">PAGE GUIDE</p>
      <h2 class="mt-3 text-2xl font-black text-brand-navy">{title}</h2>
    </div>
    <nav class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3" aria-label={title}>
      {sections.map((section) => (
        <a class="group border border-slate-200 bg-white p-5 transition hover:border-brand-blue hover:shadow-sm" href={resolveHref(section.href)}>
          <span class="flex items-center justify-between gap-3 text-base font-extrabold text-brand-navy">
            {section.label}
            <span class="text-brand-blue transition group-hover:translate-x-1" aria-hidden="true">→</span>
          </span>
          <span class="mt-2 block text-sm leading-6 text-slate-600">{section.description}</span>
        </a>
      ))}
    </nav>
  </div>
</section>
