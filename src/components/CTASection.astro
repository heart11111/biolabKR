---
import { site } from "@/data/site";
import { withBase } from "@/lib/path";

type Props = {
  id?: string;
};

const { id } = Astro.props;
---

<section id={id} class="bg-brand-navy py-16 text-white">
  <div class="container-page flex flex-col items-start justify-between gap-8 lg:flex-row lg:items-center">
    <div>
      <p class="mb-3 text-sm font-bold tracking-[0.24em] text-emerald-200">CONTACT</p>
      <h2 class="text-3xl font-black">제품, 원료, 유통 제휴 문의</h2>
      <p class="mt-4 max-w-2xl text-slate-200">
        비오랩의 iHEAL 브랜드, 해외 유통, 원료 및 제품 협업에 대해 문의해 주세요.
      </p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a class="bg-white px-7 py-4 text-sm font-bold text-brand-navy" href={`mailto:${site.email}`}>이메일 문의</a>
      <a class="border border-white/60 px-7 py-4 text-sm font-bold text-white" href={withBase("/support/contact/")}>고객지원</a>
    </div>
  </div>
</section>
