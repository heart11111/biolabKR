---
import { site } from "@/data/site";
import { withBase } from "@/lib/path";

const nav = site.navigation;
const basePath = import.meta.env.BASE_URL || "/";
const currentPath = Astro.url.pathname;
const pathWithoutBase = basePath !== "/" && currentPath.startsWith(basePath)
  ? `/${currentPath.slice(basePath.length)}`
  : currentPath;
const normalizedPath = pathWithoutBase.endsWith("/") ? pathWithoutBase : `${pathWithoutBase}/`;
const isActive = (href: string) => href !== "/" && normalizedPath.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="hidden border-b border-slate-100 bg-slate-50 text-[13px] text-slate-600 lg:block">
    <div class="container-page flex h-9 items-center justify-end gap-5">
      <a class="hover:text-brand-blue" href={withBase("/")}>Home</a>
      <a class="hover:text-brand-blue" href={withBase("/support/contact/")}>Contact Us</a>
      <a class="rounded-full bg-brand-green px-4 py-1 font-semibold text-white" href={site.japanUrl}>BIOLAB JAPAN</a>
    </div>
  </div>
  <div class="container-page flex h-[76px] items-center justify-between gap-6">
    <a class="flex items-center gap-3" href={withBase("/")} aria-label={`${site.name} 홈`}>
      <span class="flex h-11 w-11 items-center justify-center rounded-sm bg-brand-navy text-lg font-black text-white">B</span>
      <span>
        <span class="block text-[20px] font-extrabold tracking-[0.08em] text-brand-navy">{site.englishName}</span>
        <span class="block text-xs font-semibold text-brand-green">{site.name}</span>
      </span>
    </a>

    <nav class="hidden items-center gap-10 lg:flex" aria-label="주요 메뉴">
      {nav.map((item) => (
        <a
          class:list={[
            "relative py-7 text-[17px] font-semibold hover:text-brand-blue",
            isActive(item.href) ? "text-brand-blue after:absolute after:inset-x-0 after:bottom-0 after:h-[3px] after:bg-brand-blue" : "text-slate-800"
          ]}
          href={withBase(item.href)}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-2 lg:flex">
      <a
        class="flex h-11 w-11 items-center justify-center border border-slate-200 text-slate-700 hover:border-brand-blue hover:text-brand-blue"
        href={withBase("/health/")}
        aria-label="건강정보 검색"
      >
        <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
      </a>
      <button
        class="flex h-11 w-11 items-center justify-center border border-slate-200 text-slate-700 hover:border-brand-blue hover:text-brand-blue"
        type="button"
        data-mobile-toggle
        aria-label="전체 메뉴 열기"
      >
        <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 18h16"></path>
        </svg>
      </button>
    </div>

    <button
      class="flex h-11 w-11 items-center justify-center border border-slate-200 text-slate-700 lg:hidden"
      type="button"
      data-mobile-toggle
      aria-label="모바일 메뉴 열기"
    >
      <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16"></path>
        <path d="M4 12h16"></path>
        <path d="M4 18h16"></path>
      </svg>
    </button>
  </div>
</header>

<div class="mobile-panel fixed inset-0 z-[60] hidden min-h-screen bg-white" data-mobile-panel>
  <div class="container-page flex h-[76px] items-center justify-between border-b border-slate-200">
    <strong class="text-lg text-brand-navy">{site.name}</strong>
    <button class="flex h-10 w-10 items-center justify-center border border-slate-200" type="button" data-mobile-close aria-label="모바일 메뉴 닫기">
      <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>
  <nav class="container-page py-7" aria-label="전체 메뉴">
    <ul class="space-y-2">
      {nav.map((item) => (
        <li>
          <a
            class:list={[
              "block border-b border-slate-100 py-4 text-lg font-semibold",
              isActive(item.href) ? "text-brand-blue" : "text-slate-900"
            ]}
            href={withBase(item.href)}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="mt-8 grid grid-cols-2 gap-3 text-sm sm:max-w-md">
      <a class="border border-slate-200 px-4 py-3 text-center" href={withBase("/support/contact/")}>Contact</a>
      <a class="border border-slate-200 px-4 py-3 text-center" href={site.japanUrl}>BIOLAB JAPAN</a>
    </div>
  </nav>
</div>

<script>
  const toggles = document.querySelectorAll("[data-mobile-toggle]");
  const panel = document.querySelector("[data-mobile-panel]");
  const close = document.querySelector("[data-mobile-close]");

  const openPanel = () => {
    panel?.classList.remove("hidden");
    document.body.classList.add("mobile-menu-open");
  };

  const closePanel = () => {
    panel?.classList.add("hidden");
    document.body.classList.remove("mobile-menu-open");
  };

  toggles.forEach((button) => button.addEventListener("click", openPanel));
  close?.addEventListener("click", closePanel);
  panel?.querySelectorAll("a").forEach((link) => link.addEventListener("click", closePanel));
</script>
