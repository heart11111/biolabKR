---
import { site } from "@/data/site";
import {
  companySubpages,
  productMenuSubpages,
  supportSubpages,
  technologySubpages
} from "@/data/subpages";
import { withBase } from "@/lib/path";

const nav = site.navigation;
const navChildren = {
  "/company/": companySubpages,
  "/technology/": technologySubpages,
  "/products/": productMenuSubpages,
  "/support/": supportSubpages
};
const navGroups = nav.map((item) => ({
  ...item,
  children: navChildren[item.href as keyof typeof navChildren] ?? []
}));
const mobileMenuGroups = navGroups;
const basePath = import.meta.env.BASE_URL || "/";
const currentPath = Astro.url.pathname;
const pathWithoutBase = basePath !== "/" && currentPath.startsWith(basePath)
  ? `/${currentPath.slice(basePath.length)}`
  : currentPath;
const normalizedPath = pathWithoutBase.endsWith("/") ? pathWithoutBase : `${pathWithoutBase}/`;
const isActive = (href: string) => href !== "/" && normalizedPath.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-neutral-200 bg-white">
  <div class="hidden border-b border-neutral-200 bg-white text-[13px] text-neutral-500 lg:block">
    <div class="container-page flex h-9 items-center justify-end gap-4">
      <a class="font-semibold hover:text-brand-green" href={withBase("/")}>Home</a>
      <span class="h-3 w-px bg-neutral-300" aria-hidden="true"></span>
      <a class="font-semibold hover:text-brand-green" href={withBase("/support/contact/")}>Contact Us</a>
      <div class="ml-2 inline-flex overflow-hidden rounded-full border border-neutral-200 bg-neutral-100 text-xs font-extrabold" aria-label="언어 선택">
        <a class="bg-brand-green px-5 py-1.5 text-white" href={withBase("/")} aria-current="true">KOR</a>
        <a class="px-5 py-1.5 text-neutral-500 transition hover:bg-white hover:text-brand-green" href="#" aria-label="English version">ENG</a>
      </div>
    </div>
  </div>
  <div class="container-page flex h-[80px] items-center justify-between gap-8">
    <a class="flex items-center" href={withBase("/")} aria-label={`${site.name} 홈`}>
      <img class="h-9 w-auto lg:h-10" src={withBase("/images/brand/biolab-logo.png")} alt={site.englishName} />
    </a>

    <nav class="hidden h-full flex-1 items-stretch justify-center lg:flex" aria-label="주요 메뉴">
      {navGroups.map((item) => (
        <div class="group relative flex items-center" data-desktop-menu-group>
          <button
            class:list={[
              "relative flex h-full items-center px-9 text-[18px] font-bold text-neutral-900 hover:text-brand-green",
              isActive(item.href) ? "text-brand-green after:absolute after:inset-x-9 after:bottom-0 after:h-[3px] after:bg-brand-green" : ""
            ]}
            type="button"
            data-desktop-menu-trigger
            aria-expanded="false"
          >
            {item.label}
          </button>
          <div class="invisible absolute left-1/2 top-full w-[248px] -translate-x-1/2 border-t-2 border-brand-green bg-white py-3 opacity-0 shadow-[0_20px_45px_rgba(15,23,42,0.14)] ring-1 ring-neutral-200 transition duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100" data-desktop-dropdown>
            <ul>
              {item.children.map((child) => (
                <li>
                  <a
                    class:list={[
                      "block px-6 py-3 text-[15px] font-semibold hover:bg-neutral-50 hover:text-brand-green",
                      isActive(child.href) ? "text-brand-green" : "text-neutral-700"
                    ]}
                    href={withBase(child.href)}
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </nav>

    <div class="hidden items-center gap-2 lg:flex">
      <a
        class="flex h-12 w-12 items-center justify-center border border-neutral-200 text-neutral-600 hover:border-brand-green hover:text-brand-green"
        href={withBase("/products/guide/")}
        aria-label="제품 정보 검색"
      >
        <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
      </a>
      <button
        class="flex h-12 w-12 items-center justify-center border border-neutral-200 text-neutral-600 hover:border-brand-green hover:text-brand-green"
        type="button"
        data-mobile-toggle
        aria-label="전체 메뉴 열기"
      >
        <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 18h16"></path>
        </svg>
      </button>
    </div>

    <button
      class="flex h-11 w-11 items-center justify-center border border-neutral-200 text-neutral-700 lg:hidden"
      type="button"
      data-mobile-toggle
      aria-label="모바일 메뉴 열기"
    >
      <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16"></path>
        <path d="M4 12h16"></path>
        <path d="M4 18h16"></path>
      </svg>
    </button>
  </div>
</header>

<div class="mobile-panel fixed inset-0 z-[60] hidden min-h-screen bg-white" data-mobile-panel>
  <div class="container-page flex h-[76px] items-center justify-between border-b border-neutral-200">
    <img class="h-9 w-auto" src={withBase("/images/brand/biolab-logo.png")} alt={site.englishName} />
    <button class="flex h-10 w-10 items-center justify-center border border-slate-200" type="button" data-mobile-close aria-label="모바일 메뉴 닫기">
      <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>
  <nav class="container-page py-7" aria-label="전체 메뉴">
    <ul class="space-y-3">
      {mobileMenuGroups.map((item) => (
        <li class="border-b border-slate-100 pb-3">
          <button
            class:list={[
              "flex w-full items-center justify-between py-3 text-left text-lg font-semibold",
              isActive(item.href) ? "text-brand-blue" : "text-slate-900"
            ]}
            type="button"
            data-mobile-submenu
            aria-expanded="false"
          >
            <span>{item.label}</span>
            <svg aria-hidden="true" class="h-5 w-5 transition duration-150" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </button>
          <div class="grid grid-rows-[0fr] overflow-hidden transition-all duration-200" data-mobile-submenu-panel>
            <ul class="min-h-0 space-y-1 pb-2">
              {item.children.map((child) => (
                <li>
                  <a
                    class:list={[
                      "block px-4 py-3 text-sm font-semibold",
                      isActive(child.href) ? "text-brand-blue" : "text-slate-700"
                    ]}
                    href={withBase(child.href)}
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ul>
    <div class="mt-8 grid grid-cols-2 gap-3 text-sm sm:max-w-md">
      <a class="border border-slate-200 px-4 py-3 text-center" href={withBase("/")}>Home</a>
      <a class="border border-slate-200 px-4 py-3 text-center" href={withBase("/support/contact/")}>Contact Us</a>
    </div>
    <div class="mt-4 inline-flex overflow-hidden rounded-full border border-slate-200 bg-slate-100 text-xs font-extrabold shadow-sm" aria-label="언어 선택">
      <a class="bg-brand-green px-6 py-2 text-white" href={withBase("/")} aria-current="true">KOR</a>
      <a class="px-6 py-2 text-slate-500" href="#" aria-label="English version">ENG</a>
    </div>
  </nav>
</div>

<script>
  const toggles = document.querySelectorAll("[data-mobile-toggle]");
  const panel = document.querySelector("[data-mobile-panel]");
  const close = document.querySelector("[data-mobile-close]");
  const desktopGroups = document.querySelectorAll("[data-desktop-menu-group]");
  const submenuButtons = document.querySelectorAll("[data-mobile-submenu]");

  const openPanel = () => {
    panel?.classList.remove("hidden");
    document.body.classList.add("mobile-menu-open");
  };

  const closePanel = () => {
    panel?.classList.add("hidden");
    document.body.classList.remove("mobile-menu-open");
  };

  desktopGroups.forEach((group) => {
    const trigger = group.querySelector("[data-desktop-menu-trigger]");
    const setExpanded = (expanded: boolean) => trigger?.setAttribute("aria-expanded", String(expanded));

    group.addEventListener("mouseenter", () => setExpanded(true));
    group.addEventListener("mouseleave", () => setExpanded(false));
    group.addEventListener("focusin", () => setExpanded(true));
    group.addEventListener("focusout", (event) => {
      const relatedTarget = event instanceof FocusEvent ? event.relatedTarget : null;
      if (!relatedTarget || !group.contains(relatedTarget as Node)) {
        setExpanded(false);
      }
    });
  });

  submenuButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const submenuPanel = button.parentElement?.querySelector("[data-mobile-submenu-panel]");
      const isOpen = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", String(!isOpen));
      button.querySelector("svg")?.classList.toggle("rotate-180", !isOpen);
      submenuPanel?.classList.toggle("grid-rows-[0fr]", isOpen);
      submenuPanel?.classList.toggle("grid-rows-[1fr]", !isOpen);
    });
  });

  toggles.forEach((button) => button.addEventListener("click", openPanel));
  close?.addEventListener("click", closePanel);
  panel?.querySelectorAll("a").forEach((link) => link.addEventListener("click", closePanel));
</script>
