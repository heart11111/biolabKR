---
type Props = {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
};

const { eyebrow, title, description, align = "center" } = Astro.props;
---

<div class:list={["mb-10", align === "center" ? "text-center" : "text-left"]}>
  {eyebrow && <p class="mb-4 text-sm font-black tracking-[0.2em] text-brand-green">{eyebrow}</p>}
  <h2 class="text-4xl font-light leading-tight text-neutral-900 [overflow-wrap:anywhere] sm:text-5xl">{title}</h2>
  {description && <p class:list={["mt-6 max-w-[320px] break-all text-base leading-8 text-neutral-700 [overflow-wrap:anywhere] sm:max-w-3xl", align === "center" ? "mx-auto" : ""]}>{description}</p>}
</div>
