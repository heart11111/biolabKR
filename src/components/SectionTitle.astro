---
type Props = {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
};

const { eyebrow, title, description, align = "center" } = Astro.props;
---

<div class:list={["mb-10", align === "center" ? "text-center" : "text-left"]}>
  {eyebrow && <p class="mb-3 text-sm font-extrabold tracking-[0.24em] text-brand-green">{eyebrow}</p>}
  <h2 class="text-3xl font-extrabold leading-tight text-brand-navy sm:text-4xl">{title}</h2>
  {description && <p class="mx-auto mt-4 max-w-3xl text-base leading-7 text-slate-600">{description}</p>}
</div>

