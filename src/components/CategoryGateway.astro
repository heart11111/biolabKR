---
import SectionTitle from "@/components/SectionTitle.astro";
import Icon from "@/components/Icon.astro";
import { site } from "@/data/site";
import { withBase } from "@/lib/path";
---

<section class="section-band bg-white" data-category-gateway>
  <div class="container-page">
    <SectionTitle
      eyebrow="SITE MENU"
      title="비오랩 홀딩스 주요 정보"
      description="회사, 원료와 기술, 제품, 건강정보, 고객지원까지 비오랩 홀딩스의 핵심 정보를 한눈에 안내합니다."
    />

    <div class="grid gap-5 lg:grid-cols-5">
      {site.categoryGateway.map((item) => (
        <a
          class="group flex min-h-[260px] flex-col border border-slate-200 bg-white p-7 transition hover:border-brand-blue hover:bg-slate-50 hover:shadow-corporate"
          href={withBase(item.href)}
        >
          <div class="mb-5 flex h-14 w-14 items-center justify-center border border-brand-blue/20 bg-brand-mint text-brand-blue">
            <Icon name={item.icon} class="h-7 w-7" />
          </div>
          <span class="text-xs font-black tracking-[0.22em] text-brand-green">{item.eyebrow}</span>
          <strong class="mt-5 block text-2xl font-black text-brand-navy">{item.label}</strong>
          <p class="mt-4 flex-1 text-sm leading-7 text-slate-600">{item.summary}</p>
          <div class="mt-6 flex flex-wrap gap-2">
            {item.sections.slice(0, 4).map((section) => (
              <span class="border border-slate-200 bg-white px-3 py-1 text-xs font-bold text-slate-600">{section}</span>
            ))}
          </div>
          <span class="mt-7 inline-flex items-center text-sm font-extrabold text-brand-blue">
            자세히 보기 <span class="ml-2 transition group-hover:translate-x-1" aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
