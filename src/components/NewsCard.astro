---
import type { NewsItem } from "@/data/news";
import { withBase } from "@/lib/path";

type Props = {
  item: NewsItem;
};

const { item } = Astro.props;
---

<article class="border-b border-slate-200 py-6">
  <a class="block hover:text-brand-blue" href={withBase(item.href)}>
    <div class="mb-3 flex flex-wrap items-center gap-3 text-sm">
      <span class="bg-slate-100 px-3 py-1 font-bold text-brand-navy">{item.category}</span>
      <time class="text-slate-500">{item.date}</time>
    </div>
    <h3 class="text-xl font-extrabold text-slate-900">{item.title}</h3>
    <p class="mt-3 text-sm leading-7 text-slate-600">{item.summary}</p>
  </a>
</article>

