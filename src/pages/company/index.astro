---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import SubpageGrid from "@/components/SubpageGrid.astro";
import CTASection from "@/components/CTASection.astro";
import { site } from "@/data/site";
import { companySubpages } from "@/data/subpages";
---

<BaseLayout title="회사소개" description="비오랩의 비전, 회사 개요, 연혁, 파트너, 오시는 길을 소개합니다.">
  <SubHero title="회사소개" description="여성과 아이의 건강을 위한 브랜드와 제품을 연구하며 글로벌 헬스케어 기업으로 성장합니다." />
  <Breadcrumb current="회사소개" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle
        eyebrow="COMPANY"
        title="건강한 일상을 위한 브랜드를 운영합니다"
        description="비오랩은 여성과 아이의 건강을 중심으로 브랜드 전략, 제품 기획, 유통 네트워크를 확장해 가고 있습니다."
      />
      <SubpageGrid items={companySubpages} />
    </div>
  </section>

  <section class="section-band bg-slate-50">
    <div class="container-page grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {site.stats.map((stat) => (
        <div class="border border-slate-200 bg-white p-7 shadow-sm">
          <strong class="block text-3xl font-black text-brand-blue">{stat.value}</strong>
          <span class="mt-2 block text-sm font-semibold text-slate-600">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <CTASection />
</BaseLayout>
