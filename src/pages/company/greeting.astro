---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import CTASection from "@/components/CTASection.astro";
import { companySubpages } from "@/data/subpages";
import { withBase } from "@/lib/path";
---

<BaseLayout title="대표 인사말" description="비오랩의 브랜드 철학과 대표 메시지를 소개합니다.">
  <SubHero title="대표 인사말" description="여성과 아이의 건강한 일상에 닿는 제품을 만들겠습니다." />
  <Breadcrumb parent={{ label: "회사소개", href: "/company/" }} current="대표 인사말" />

  <section class="section-band bg-white">
    <div class="container-page">
      <nav class="mb-16 grid overflow-hidden border border-slate-200 bg-white text-center text-sm font-extrabold text-slate-700 md:grid-cols-5" aria-label="회사소개 하위 메뉴">
        {companySubpages.map((item) => (
          <a
            class:list={[
              "border-b border-slate-200 px-4 py-4 transition hover:bg-brand-mint hover:text-brand-green md:border-b-0 md:border-r",
              item.href === "/company/greeting/" ? "bg-brand-green text-white hover:bg-brand-green hover:text-white" : "bg-white",
              item.href === companySubpages[companySubpages.length - 1].href ? "md:border-r-0" : ""
            ]}
            href={withBase(item.href)}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="grid gap-14 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <figure class="relative mx-auto w-full max-w-[520px] pb-6 pl-6">
          <div class="absolute bottom-0 left-0 h-[72%] w-[82%] bg-brand-green" aria-hidden="true"></div>
          <img
            class="relative aspect-[4/3] w-full border border-slate-200 object-cover shadow-sm"
            src={withBase("/images/ingredients/ingredient-research-lab.jpg")}
            alt="비오랩 원료 연구 이미지"
          />
        </figure>

        <div class="text-slate-700">
          <p class="mb-5 text-sm font-black tracking-[0.26em] text-brand-green">CEO MESSAGE</p>
          <h2 class="text-3xl font-black leading-tight text-brand-navy md:text-4xl">
            반갑습니다.<br />
            비오랩 홈페이지를 방문해 주신 모든 분들께 진심으로 감사드립니다.
          </h2>

          <div class="mt-8 space-y-5 text-base leading-8">
            <p>
              비오랩은 여성과 아이의 건강한 일상을 위해 원료를 고르는 기준, 제품을 설계하는 태도, 고객에게 전달되는 경험까지
              신중하게 다루는 헬스케어 브랜드 기업입니다.
            </p>
            <p>
              iHEAL은 “나와 아이의 건강”이라는 의미를 담고 있습니다. 특허 유산균과 검증된 원료를 기반으로, 일상에서 꾸준히
              선택할 수 있는 제품을 만들고 국내외 유통 채널을 통해 더 많은 고객과 만나고 있습니다.
            </p>
            <p>
              건강기능식품 시장은 빠르게 변하고 있지만, 비오랩이 지켜야 할 기준은 분명합니다. 단기적인 성과보다 제품력,
              품질관리, 지속 가능한 브랜드 운영을 우선하며 고객의 신뢰를 쌓아가겠습니다.
            </p>
            <p>
              앞으로도 비오랩은 여성 건강, 키즈 건강, 이너케어 분야에서 실질적인 도움이 되는 제품을 제안하고, 더 건강한
              생활 기준을 만드는 기업으로 성장하겠습니다.
            </p>
          </div>

          <div class="mt-10 text-right text-lg font-semibold text-slate-900">
            비오랩 대표이사 드림
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
