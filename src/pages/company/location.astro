---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import CTASection from "@/components/CTASection.astro";
import Icon from "@/components/Icon.astro";
import { companySubpages } from "@/data/subpages";
import { site } from "@/data/site";
import { withBase } from "@/lib/path";
---

<BaseLayout title="찾아오시는 길" description="비오랩 위치와 방문 안내를 소개합니다.">
  <SubHero title="찾아오시는 길" description="방문 상담은 사전 예약 후 안내드리며, 제품·원료·유통 제휴 문의는 대표 연락처로 접수합니다." />
  <Breadcrumb parent={{ label: "회사소개", href: "/company/" }} current="찾아오시는 길" />

  <section class="section-band bg-white">
    <div class="container-page">
      <nav class="mb-16 grid overflow-hidden border border-slate-200 bg-white text-center text-sm font-extrabold text-slate-700 md:grid-cols-5" aria-label="회사소개 하위 메뉴">
        {companySubpages.map((item) => (
          <a
            class:list={[
              "border-b border-slate-200 px-4 py-4 transition hover:bg-brand-mint hover:text-brand-green md:border-b-0 md:border-r",
              item.href === "/company/location/" ? "bg-brand-green text-white hover:bg-brand-green hover:text-white" : "bg-white",
              item.href === companySubpages[companySubpages.length - 1].href ? "md:border-r-0" : ""
            ]}
            href={withBase(item.href)}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="mb-10 text-center">
        <p class="mb-3 text-sm font-black tracking-[0.28em] text-brand-green">LOCATION</p>
        <h2 class="text-3xl font-black text-brand-navy md:text-4xl">비오랩 찾아오시는 길</h2>
        <p class="mx-auto mt-4 max-w-3xl text-base leading-7 text-slate-600">
          경기도 성남시 분당구 궁내동에 위치해 있으며, 방문 상담은 사전 예약제로 운영합니다.
        </p>
      </div>

      <div class="overflow-hidden border border-slate-200 bg-white shadow-sm">
        <div class="relative h-[360px] bg-slate-100 md:h-[520px]">
          <iframe
            class="absolute inset-0 h-full w-full"
            title="비오랩 위치 지도"
            src="https://www.openstreetmap.org/export/embed.html?bbox=127.0940%2C37.3596%2C127.1062%2C37.3676&layer=mapnik&marker=37.3636446%2C127.1000766"
            loading="lazy"
          ></iframe>
        </div>

        <div class="grid bg-brand-green text-white lg:grid-cols-[1.5fr_0.75fr_0.9fr]">
          <div class="flex items-center gap-5 border-b border-white/20 px-6 py-7 lg:border-b-0 lg:border-r">
            <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-white text-brand-green">
              <Icon name="map" class="h-7 w-7" />
            </span>
            <div>
              <p class="text-xs font-black tracking-[0.22em] text-emerald-100">ADDRESS</p>
              <p class="mt-2 text-lg font-extrabold leading-7">{site.address}</p>
            </div>
          </div>
          <div class="flex items-center gap-5 border-b border-white/20 px-6 py-7 lg:border-b-0 lg:border-r">
            <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-white text-brand-green">
              <Icon name="headset" class="h-7 w-7" />
            </span>
            <div>
              <p class="text-xs font-black tracking-[0.22em] text-emerald-100">TEL</p>
              <p class="mt-2 text-lg font-extrabold">{site.phone}</p>
            </div>
          </div>
          <div class="flex items-center gap-5 px-6 py-7">
            <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-white text-brand-green">
              <Icon name="faq" class="h-7 w-7" />
            </span>
            <div>
              <p class="text-xs font-black tracking-[0.22em] text-emerald-100">EMAIL</p>
              <p class="mt-2 text-lg font-extrabold">{site.email}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        <div class="border border-slate-200 p-6">
          <p class="text-sm font-black tracking-[0.2em] text-brand-green">VISIT</p>
          <h3 class="mt-3 text-xl font-black text-brand-navy">방문 안내</h3>
          <p class="mt-3 leading-7 text-slate-600">제품, 원료, 유통 제휴 상담은 일정 확인 후 방문하실 수 있습니다.</p>
        </div>
        <div class="border border-slate-200 p-6">
          <p class="text-sm font-black tracking-[0.2em] text-brand-green">BUSINESS</p>
          <h3 class="mt-3 text-xl font-black text-brand-navy">상담 분야</h3>
          <p class="mt-3 leading-7 text-slate-600">건강기능식품, 이너케어 제품, 국내외 유통 및 브랜드 제휴 문의를 접수합니다.</p>
        </div>
        <div class="border border-slate-200 p-6">
          <p class="text-sm font-black tracking-[0.2em] text-brand-green">MAP</p>
          <h3 class="mt-3 text-xl font-black text-brand-navy">외부 지도</h3>
          <a
            class="mt-3 inline-flex font-extrabold text-brand-blue hover:text-brand-green"
            href="https://www.openstreetmap.org/?mlat=37.3636446&mlon=127.1000766#map=17/37.3636446/127.1000766"
            target="_blank"
            rel="noreferrer"
          >
            큰 지도에서 보기 →
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
