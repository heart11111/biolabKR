---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import CTASection from "@/components/CTASection.astro";
import { site } from "@/data/site";
import { withBase } from "@/lib/path";
---

<BaseLayout title="주요 파트너" description="비오랩의 국내외 유통 채널과 파트너를 소개합니다.">
  <SubHero title="주요 파트너" description="국내외 온라인과 오프라인 채널에서 iHEAL 브랜드 접점을 넓히고 있습니다." />
  <Breadcrumb parent={{ label: "회사소개", href: "/company/" }} current="주요 파트너" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="PARTNERS" title="국내외 채널 네트워크" description="국내 약국·면세점 채널과 Qoo10, 라쿠텐, 아마존, 일본 주요 오프라인 채널을 중심으로 브랜드 신뢰를 축적하고 있습니다." />
      <div class="grid border-l border-t border-slate-200 sm:grid-cols-2 lg:grid-cols-4">
        {site.partners.map((partner) => (
          <div class="flex min-h-[164px] flex-col items-center justify-center border-b border-r border-slate-200 bg-white px-6 py-8 text-center transition hover:bg-slate-50">
            <div class="flex h-16 w-full items-center justify-center">
              <img src={withBase(partner.logo)} alt={`${partner.name} CI`} loading="lazy" class="max-h-12 max-w-[170px] object-contain" />
            </div>
            <strong class="mt-5 text-lg font-extrabold text-slate-800">{partner.name}</strong>
            <span class="mt-2 text-xs font-bold uppercase tracking-[0.16em] text-brand-green">{partner.region}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band bg-slate-50">
    <div class="container-page grid gap-6 md:grid-cols-3">
      <article class="border-t-4 border-brand-green bg-white p-7"><h2 class="text-xl font-black text-brand-navy">국내 채널</h2><p class="mt-4 text-sm leading-7 text-slate-600">자사몰, 쿠팡 로켓, 올 그레이스 면세점, 온누리 약국 등으로 국내 소비자 접점을 확장합니다.</p></article>
      <article class="border-t-4 border-brand-green bg-white p-7"><h2 class="text-xl font-black text-brand-navy">일본 온라인</h2><p class="mt-4 text-sm leading-7 text-slate-600">Qoo10 건기식 카테고리 1위, 전체 랭킹 1위, Qoo10 어워즈 수상 흐름을 기반으로 성장했습니다.</p></article>
      <article class="border-t-4 border-brand-green bg-white p-7"><h2 class="text-xl font-black text-brand-navy">일본 오프라인</h2><p class="mt-4 text-sm leading-7 text-slate-600">2026년 1월부터 웰시아, 이토요카도, 스기약국, 돈키호테 등 주요 오프라인 채널 입점이 순차적으로 진행됩니다.</p></article>
    </div>
  </section>

  <CTASection />
</BaseLayout>
