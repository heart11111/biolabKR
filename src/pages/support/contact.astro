---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import { site } from "@/data/site";
---

<BaseLayout title="문의하기" description="비오랩 홀딩스 제품, 원료, 유통 제휴 문의 연락처를 안내합니다.">
  <SubHero title="문의하기" description="제품, 원료, 유통 제휴, 해외 채널 문의를 위한 연락처입니다." />
  <Breadcrumb parent={{ label: "고객지원", href: "/support/" }} current="문의하기" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="CONTACT" title="문의하기" description="정적 사이트이므로 실제 전송 기능은 없습니다. 배포 후 Formspree, Google Forms, 이메일 링크 등으로 교체할 수 있습니다." />
      <div class="grid gap-8 lg:grid-cols-2">
        <table class="table-corporate">
          <tbody>
            <tr><th>대표번호</th><td>{site.phone}</td></tr>
            <tr><th>팩스</th><td>{site.fax}</td></tr>
            <tr><th>이메일</th><td><a class="text-brand-blue" href={`mailto:${site.email}`}>{site.email}</a></td></tr>
            <tr><th>주소</th><td>{site.address}</td></tr>
            <tr><th>제휴 문의</th><td>국내 입점, 해외 유통, 제품 자료 요청, 브랜드 협업 문의</td></tr>
          </tbody>
        </table>
        <form class="border border-slate-200 bg-slate-50 p-7">
          <label class="mb-2 block text-sm font-bold text-slate-700" for="name">이름</label>
          <input id="name" class="mb-4 w-full border border-slate-200 px-4 py-3" type="text" placeholder="홍길동" disabled />
          <label class="mb-2 block text-sm font-bold text-slate-700" for="email">이메일</label>
          <input id="email" class="mb-4 w-full border border-slate-200 px-4 py-3" type="email" placeholder="name@example.com" disabled />
          <label class="mb-2 block text-sm font-bold text-slate-700" for="message">문의 내용</label>
          <textarea id="message" class="h-32 w-full border border-slate-200 px-4 py-3" placeholder="문의 내용을 입력하세요" disabled></textarea>
          <button class="mt-5 bg-brand-navy px-6 py-3 text-sm font-bold text-white" type="button" disabled>문의 기능 준비중</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
