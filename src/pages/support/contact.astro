---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import { site } from "@/data/site";
---

<BaseLayout title="문의하기" description="비오랩 제품, 원료, 유통 제휴 문의 연락처를 안내합니다.">
  <SubHero title="문의하기" description="제품, 원료, 유통 제휴, 해외 채널 문의를 위한 연락처입니다." />
  <Breadcrumb parent={{ label: "고객지원", href: "/support/" }} current="문의하기" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="CONTACT" title="문의하기" description="제품, 원료, 유통 제휴 문의는 대표 이메일로 접수해 주세요. 담당 부서 확인 후 순차적으로 안내드립니다." />
      <div class="grid gap-8 lg:grid-cols-2">
        <table class="table-corporate">
          <tbody>
            <tr><th>대표번호</th><td>{site.phone}</td></tr>
            <tr><th>팩스</th><td>{site.fax}</td></tr>
            <tr><th>이메일</th><td><a class="text-brand-blue" href={`mailto:${site.email}`}>{site.email}</a></td></tr>
            <tr><th>주소</th><td>{site.address}</td></tr>
            <tr><th>제휴 문의</th><td>국내 입점, 해외 유통, 제품 자료 요청, 브랜드 협업 문의</td></tr>
          </tbody>
        </table>
        <div class="border border-slate-200 bg-slate-50 p-7">
          <h2 class="text-2xl font-black text-brand-navy">상담 접수 안내</h2>
          <p class="mt-4 text-sm leading-7 text-slate-600">
            문의 시 회사명, 담당자명, 연락처, 문의 목적을 함께 보내주시면 더 빠르게 확인할 수 있습니다.
          </p>
          <div class="mt-6 grid gap-3 text-sm text-slate-700">
            <p><strong class="text-brand-navy">제품 문의</strong> 제품 자료, 성분, 섭취 안내</p>
            <p><strong class="text-brand-navy">입점 문의</strong> 국내외 유통, 온라인 채널, 오프라인 매장</p>
            <p><strong class="text-brand-navy">제휴 문의</strong> 원료, 제조, 브랜드 협업, 해외 사업</p>
          </div>
          <a class="mt-7 inline-flex bg-brand-navy px-6 py-3 text-sm font-bold text-white" href={`mailto:${site.email}`}>이메일 문의</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
