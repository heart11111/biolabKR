---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import SubpageGrid from "@/components/SubpageGrid.astro";
import { supportSubpages } from "@/data/subpages";
---

<BaseLayout title="고객지원" description="비오랩 홀딩스 공지사항, FAQ, 문의 연락처를 안내합니다.">
  <SubHero title="고객지원" description="공지사항, FAQ, 문의하기를 각각 별도 페이지로 확인할 수 있습니다." />
  <Breadcrumb current="고객지원" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="SUPPORT" title="필요한 고객지원 메뉴를 선택하세요" description="공지사항과 문의 정보를 한 페이지에 몰아넣지 않고, 필요한 내용별로 분리했습니다." />
      <SubpageGrid items={supportSubpages} />
    </div>
  </section>
</BaseLayout>
