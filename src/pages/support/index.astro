---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import SubpageGrid from "@/components/SubpageGrid.astro";
import { supportSubpages } from "@/data/subpages";
---

<BaseLayout title="고객지원" description="비오랩 공지사항, FAQ, 문의 연락처를 안내합니다.">
  <SubHero title="고객지원" description="비오랩의 주요 소식과 문의 안내, 자주 묻는 질문을 제공합니다." />
  <Breadcrumb current="고객지원" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="SUPPORT" title="고객지원 안내" description="브랜드 소식, 제품 문의, 제휴 상담에 필요한 정보를 빠르게 찾을 수 있도록 안내합니다." />
      <SubpageGrid items={supportSubpages} />
    </div>
  </section>
</BaseLayout>
