---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import NewsBoard from "@/components/NewsBoard.astro";
import { news, supportNewsCategories } from "@/data/news";
---

<BaseLayout title="공지사항 / 보도자료" description="비오랩 홀딩스의 브랜드 소식, 입점, 수상, 보도자료를 안내합니다.">
  <SubHero title="공지사항 / 보도자료" description="브랜드 소식, 입점, 수상, 보도자료를 기업 게시판 형식으로 확인할 수 있습니다." />
  <Breadcrumb parent={{ label: "고객지원", href: "/support/" }} current="공지사항 / 보도자료" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="NEWS" title="비오랩 홀딩스 소식" description="비오랩 홀딩스와 iHEAL 브랜드의 주요 소식을 카테고리별 게시판 형태로 정리했습니다." />
      <NewsBoard items={news} categories={supportNewsCategories} />
    </div>
  </section>
</BaseLayout>
