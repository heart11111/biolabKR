---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import FAQList from "@/components/FAQList.astro";
import CTASection from "@/components/CTASection.astro";
import { faqs } from "@/data/faqs";
---

<BaseLayout title="FAQ" description="비오랩 홀딩스의 자주 묻는 질문을 안내합니다.">
  <SubHero title="FAQ" description="제품, 입점, 제휴 문의와 관련해 자주 묻는 내용을 안내합니다." />
  <Breadcrumb parent={{ label: "고객지원", href: "/support/" }} current="FAQ" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="FAQ" title="자주 묻는 질문" />
      <FAQList items={faqs} />
    </div>
  </section>

  <CTASection />
</BaseLayout>
