---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PageSectionNav from "@/components/PageSectionNav.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import CTASection from "@/components/CTASection.astro";
import { site } from "@/data/site";
import { articles } from "@/data/articles";
import { withBase } from "@/lib/path";

const topics = Array.from(new Set(articles.map((article) => article.category))).map((category) => ({
  category,
  count: articles.filter((article) => article.category === category).length
}));
---

<BaseLayout title="건강정보" description="여성 건강, 이너케어, 키즈 건강 관련 정보를 정적 게시글로 제공합니다.">
  <SubHero title="건강정보" description="DB 없이 정적 데이터로 관리되는 건강 칼럼과 정보형 콘텐츠입니다." />
  <Breadcrumb current="건강정보" />
  <PageSectionNav sections={site.pageSections.health} />

  <section id="topics" class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="TOPICS" title="건강정보 주제" description="여성 건강, 이너케어, 키즈 건강 등 제품과 연결되는 정보 콘텐츠를 주제별로 관리합니다." />
      <div class="grid gap-5 md:grid-cols-3">
        {topics.map((topic) => (
          <div class="border border-slate-200 bg-slate-50 p-7">
            <strong class="text-xl font-black text-brand-navy">{topic.category}</strong>
            <p class="mt-4 text-sm leading-7 text-slate-600">관련 칼럼 {topic.count}건이 등록되어 있습니다.</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="articles" class="section-band bg-slate-50">
    <div class="container-page">
      <SectionTitle eyebrow="HEALTH COLUMN" title="건강정보 카드" description="각 카드는 별도 상세 페이지로 연결되며, 데이터 파일에서 쉽게 추가하거나 교체할 수 있습니다." />
      <div class="grid gap-6 md:grid-cols-3">
        {articles.map((article) => (
          <article class="overflow-hidden border border-slate-200 bg-white shadow-sm hover:shadow-corporate">
            <a href={withBase(`/health/${article.slug}/`)}>
              <img class="h-52 w-full object-cover" src={withBase(article.image)} alt={article.title} />
              <div class="p-6">
                <div class="mb-3 flex items-center gap-3 text-sm">
                  <span class="font-bold text-brand-green">{article.category}</span>
                  <time class="text-slate-500">{article.date}</time>
                </div>
                <h2 class="text-xl font-extrabold text-brand-navy">{article.title}</h2>
                <p class="mt-4 text-sm leading-7 text-slate-600">{article.excerpt}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection id="health-contact" />
</BaseLayout>
