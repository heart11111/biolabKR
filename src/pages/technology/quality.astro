---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import CTASection from "@/components/CTASection.astro";
---

<BaseLayout title="품질관리" description="비오랩 홀딩스의 원료 규격, 표시사항, 제조·유통 관리 방향을 소개합니다.">
  <SubHero title="품질관리" description="원료부터 표시 문구와 유통 이력까지 단계별 확인 기준을 유지합니다." />
  <Breadcrumb parent={{ label: "원료/기술", href: "/technology/" }} current="품질관리" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="QUALITY" title="신뢰를 위한 품질관리 체계" description="건강기능식품과 이너케어 제품은 반복 구매와 장기 신뢰가 중요하므로, 자료 관리와 표시 기준을 함께 관리합니다." />
      <div class="grid gap-6 md:grid-cols-3">
        {["원료 규격 확인", "제조/유통 이력 관리", "표시 문구 검토"].map((item, index) => (
          <article class="border-t-4 border-brand-blue bg-slate-50 p-7">
            <span class="text-sm font-black text-brand-green">0{index + 1}</span>
            <h2 class="mt-5 text-xl font-extrabold text-brand-navy">{item}</h2>
            <p class="mt-4 text-sm leading-7 text-slate-600">제품 신뢰도를 높이기 위해 단계별 확인 기준과 교체 가능한 자료 관리 구조를 둡니다.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band bg-slate-50">
    <div class="container-page">
      <table class="table-corporate">
        <tbody>
          <tr><th>원료 관리</th><td>특허 균주, 보장균수, 부원료, 외용 원료별 규격과 적용 목적을 제품 데이터에 분리해 관리합니다.</td></tr>
          <tr><th>표시 관리</th><td>건강기능식품 표현 기준을 고려해 제품 특징, 섭취 방법, 주의 문구를 추후 교체하기 쉽게 구성합니다.</td></tr>
          <tr><th>채널 관리</th><td>국내외 온오프라인 채널별 소개 자료와 제품 설명을 일관된 기준으로 정리합니다.</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <CTASection />
</BaseLayout>
