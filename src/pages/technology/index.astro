---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import SubpageGrid from "@/components/SubpageGrid.astro";
import CTASection from "@/components/CTASection.astro";
import { technologySubpages } from "@/data/subpages";
---

<BaseLayout title="원료/기술 소개" description="비오랩 홀딩스의 핵심 원료, 연구개발, 품질관리 방향을 소개합니다.">
  <SubHero title="원료/기술 소개" description="특허 유산균과 이너케어 원료를 기반으로 제품별 목적에 맞는 포뮬러를 설계합니다." />
  <Breadcrumb current="원료/기술 소개" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle
        eyebrow="TECHNOLOGY"
        title="제품 신뢰도를 높이는 원료 연구와 품질 기준"
        description="특허 유산균, 이너케어 원료, 연구개발 프로세스와 품질관리 기준을 제품 설계의 관점에서 소개합니다."
      />
      <SubpageGrid items={technologySubpages} />
    </div>
  </section>

  <CTASection />
</BaseLayout>
