---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import SubpageGrid from "@/components/SubpageGrid.astro";
import CTASection from "@/components/CTASection.astro";
import { technologySubpages } from "@/data/subpages";
import { withBase } from "@/lib/path";
---

<BaseLayout title="원료/기술 소개" description="비오랩의 핵심 원료, 연구개발, 품질관리 방향을 소개합니다.">
  <SubHero title="원료/기술 소개" description="특허 유산균과 이너케어 원료를 기반으로 제품별 목적에 맞는 포뮬러를 설계합니다." />
  <Breadcrumb current="원료/기술 소개" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle
        eyebrow="TECHNOLOGY"
        title="제품 신뢰도를 높이는 원료 연구와 품질 기준"
        description="특허 유산균, 이너케어 원료, 연구개발 프로세스와 품질관리 기준을 제품 설계의 관점에서 소개합니다."
      />

      <div class="mb-16 grid gap-7 lg:grid-cols-2" data-reveal-group>
        <article class="group" data-reveal>
          <div class="relative overflow-hidden bg-brand-navy">
            <img
              class="aspect-[16/9] w-full scale-105 object-cover object-[50%_46%] transition duration-700 group-hover:scale-110"
              src={withBase("/images/science/petri-pipette-lab.jpg")}
              alt="피펫과 배양접시를 활용한 유산균 원료 연구 이미지"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(23,50,77,0.28),rgba(88,182,166,0.1))]"></div>
          </div>
          <h2 class="mt-7 text-center text-xl font-black text-brand-navy">프로바이오틱스 원료 연구</h2>
          <p class="mx-auto mt-3 max-w-xl text-center text-sm leading-7 text-slate-600">
            특허 균주와 제품 목적에 맞는 배합 기준을 중심으로 여성·키즈 건강 포뮬러를 설계합니다.
          </p>
        </article>

        <article class="group" data-reveal>
          <div class="relative overflow-hidden bg-brand-navy">
            <img
              class="aspect-[16/9] w-full scale-105 object-cover object-[54%_50%] transition duration-700 group-hover:scale-110"
              src={withBase("/images/science/pharma-blister-packs.jpg")}
              alt="정제와 블리스터 포장 기반의 품질관리 이미지"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(23,50,77,0.36),rgba(88,182,166,0.12))]"></div>
          </div>
          <h2 class="mt-7 text-center text-xl font-black text-brand-navy">기능성 제품 품질 기준</h2>
          <p class="mx-auto mt-3 max-w-xl text-center text-sm leading-7 text-slate-600">
            원료 규격, 표시 문구, 제품 설명과 채널별 정보가 일관되게 유지되도록 관리합니다.
          </p>
        </article>
      </div>

      <SubpageGrid items={technologySubpages} />
    </div>
  </section>

  <CTASection />
</BaseLayout>
