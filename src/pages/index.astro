---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import Icon from "@/components/Icon.astro";
import ProductCard from "@/components/ProductCard.astro";
import NewsCard from "@/components/NewsCard.astro";
import CTASection from "@/components/CTASection.astro";
import { site } from "@/data/site";
import { products } from "@/data/products";
import { news } from "@/data/news";
import { withBase } from "@/lib/path";

const strengthIcons = ["dna", "network", "shield", "heartPulse"];
const animatedStats = site.stats.map((stat) => {
  const match = stat.value.match(/^([^0-9]*)([0-9]+(?:\.[0-9]+)?)(.*)$/);
  const numericText = match?.[2] ?? "0";

  return {
    ...stat,
    countPrefix: match?.[1] ?? "",
    countTarget: Number(numericText),
    countDecimals: numericText.includes(".") ? numericText.split(".")[1].length : 0,
    countSuffix: match?.[3] ?? stat.value
  };
});
---

<BaseLayout title="비오랩" description={site.description}>
  <Hero />

  <section id="about" class="section-band bg-slate-50">
    <div class="container-page grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <SectionTitle
        align="left"
        eyebrow="ABOUT BIOLAB"
        title="건강한 삶을 위한 기능성 소재와 브랜드를 만듭니다"
        description="비오랩은 iHEAL 브랜드를 중심으로 여성과 아이의 건강을 위한 건강기능식품, 이너케어, 뷰티 솔루션을 연구하고 전개합니다."
      />
      <div class="grid grid-cols-2 gap-4" data-animated-stats>
        {animatedStats.map((stat, index) => (
          <div class="border border-slate-200 bg-white p-6 shadow-sm">
            <strong
              class="block text-3xl font-black tabular-nums text-brand-blue"
              data-countup
              data-count-target={stat.countTarget}
              data-count-prefix={stat.countPrefix}
              data-count-suffix={stat.countSuffix}
              data-count-decimals={stat.countDecimals}
              data-count-index={index}
              aria-label={stat.value}
            >
              {stat.value}
            </strong>
            <span class="mt-2 block text-sm font-semibold text-slate-600">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="COMPETENCE" title="비오랩의 핵심 경쟁력" />
      <div class="grid gap-px overflow-hidden border border-slate-200 bg-slate-200 md:grid-cols-2 lg:grid-cols-4">
        {site.strengths.map((item, index) => (
          <article class="group flex h-full flex-col bg-white">
            <div class="relative aspect-[5/4] overflow-hidden bg-slate-100">
              <img
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                src={withBase(item.image)}
                alt={item.imageAlt}
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/35 via-brand-navy/5 to-transparent"></div>
              <span class="absolute left-5 top-5 block bg-white/95 px-3 py-2 text-sm font-black text-brand-green shadow-sm">
                0{index + 1}
              </span>
            </div>
            <div class="flex flex-1 flex-col p-7">
              <div class="mb-5 flex items-center justify-between">
                <span class="text-xs font-black tracking-[0.28em] text-brand-green">COMPETENCE</span>
                <span class="flex h-11 w-11 items-center justify-center border border-brand-blue/20 bg-brand-mint text-brand-blue">
                  <Icon name={strengthIcons[index]} class="h-5 w-5" />
                </span>
              </div>
              <h3 class="text-xl font-extrabold text-brand-navy">{item.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">{item.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band bg-brand-mint">
    <div class="container-page">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div>
          <SectionTitle
            align="left"
            eyebrow="PRODUCT PREVIEW"
            title="여성과 아이의 일상에 맞춘 iHEAL 대표 제품"
            description="특허 유산균과 이너케어 원료를 바탕으로 여성 건강, 키즈 건강, 뷰티 케어 제품군을 전개합니다."
          />
          <a class="inline-flex bg-brand-navy px-6 py-4 text-sm font-bold text-white" href={withBase("/products/")}>제품 라인업 보기</a>
        </div>
        <div class="grid gap-6 md:grid-cols-2">
          {products.slice(0, 2).map((product) => <ProductCard product={product} />)}
        </div>
      </div>
    </div>
  </section>

  <section class="section-band bg-white">
    <div class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <SectionTitle align="left" eyebrow="NOTICE" title="공지사항 / 보도자료" description="비오랩의 최신 소식과 브랜드 성장 소식을 전합니다." />
        <a class="inline-flex border border-brand-blue px-5 py-3 text-sm font-bold text-brand-blue" href={withBase("/support/news/")}>전체 보기</a>
      </div>
      <div>
        {news.slice(0, 3).map((item) => <NewsCard item={item} />)}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<script>
  const statsSection = document.querySelector("[data-animated-stats]");
  const counters = Array.from(document.querySelectorAll<HTMLElement>("[data-countup]"));
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const formatCounter = (value: number, decimals: number) => value.toFixed(decimals);

  const setCounterText = (counter: HTMLElement, value: number) => {
    const decimals = Number(counter.dataset.countDecimals ?? 0);
    const prefix = counter.dataset.countPrefix ?? "";
    const suffix = counter.dataset.countSuffix ?? "";
    counter.textContent = `${prefix}${formatCounter(value, decimals)}${suffix}`;
  };

  const animateCounter = (counter: HTMLElement) => {
    if (counter.dataset.countAnimated === "true") return;

    counter.dataset.countAnimated = "true";
    const target = Number(counter.dataset.countTarget ?? 0);

    if (prefersReducedMotion) {
      setCounterText(counter, target);
      return;
    }

    const duration = 1400;
    const startTime = performance.now();
    const settleTimer = window.setTimeout(() => setCounterText(counter, target), duration + 260);

    const tick = (now: number) => {
      const progress = Math.min((now - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);

      setCounterText(counter, target * eased);

      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        window.clearTimeout(settleTimer);
        setCounterText(counter, target);
      }
    };

    requestAnimationFrame(tick);
  };

  const runCounters = () => {
    counters.forEach((counter, index) => {
      window.setTimeout(() => animateCounter(counter), index * 120);
    });
  };

  counters.forEach((counter) => {
    const target = Number(counter.dataset.countTarget ?? 0);
    setCounterText(counter, prefersReducedMotion ? target : 0);
  });

  if (statsSection && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry?.isIntersecting) return;
        runCounters();
        observer.disconnect();
      },
      { threshold: 0.35 }
    );

    observer.observe(statsSection);
  } else {
    runCounters();
  }
</script>
