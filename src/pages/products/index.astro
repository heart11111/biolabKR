---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import SubpageGrid from "@/components/SubpageGrid.astro";
import ProductCard from "@/components/ProductCard.astro";
import CTASection from "@/components/CTASection.astro";
import { productSubpages } from "@/data/subpages";
import { products } from "@/data/products";
---

<BaseLayout title="제품소개" description="비오랩 홀딩스의 iHEAL 제품 라인업을 소개합니다.">
  <SubHero title="제품소개" description="여성 건강, 키즈 건강, 이너케어, 다이어트 제품군을 각각 별도 페이지로 확인하세요." />
  <Breadcrumb current="제품소개" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="PRODUCT CATEGORY" title="제품군별 페이지" description="제품 소개는 제품군별로 분리했습니다. 각 페이지에서 관련 제품과 핵심 성분을 확인할 수 있습니다." />
      <SubpageGrid items={productSubpages} />
    </div>
  </section>

  <section class="section-band bg-slate-50">
    <div class="container-page">
      <SectionTitle eyebrow="ALL PRODUCTS" title="전체 제품" description="개별 제품 상세 페이지는 제품 카드에서 바로 확인할 수 있습니다." />
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
