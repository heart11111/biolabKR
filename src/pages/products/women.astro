---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import ProductCard from "@/components/ProductCard.astro";
import CTASection from "@/components/CTASection.astro";
import { products } from "@/data/products";

const womenProducts = products.filter((product) => product.slug.includes("venus") && product.slug !== "venus-inner-perfume");
---

<BaseLayout title="여성 건강 제품" description="아이힐 비너스 유산균과 비너스 유산균 스틱을 소개합니다.">
  <SubHero title="여성 건강" description="건강한 한국 여성 유래 특허 유산균 3종을 기반으로 한 여성 맞춤형 라인입니다." />
  <Breadcrumb parent={{ label: "제품소개", href: "/products/" }} current="여성 건강" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="WOMEN PROBIOTICS" title="비너스 유산균 라인" description="MG242, MG901, MG989 특허 균주를 중심으로 여성의 데일리 건강 루틴을 제안합니다." />
      <div class="grid gap-6 md:grid-cols-2">
        {womenProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="section-band bg-slate-50">
    <div class="container-page grid gap-6 md:grid-cols-3">
      <article class="border border-slate-200 bg-white p-7"><h2 class="text-xl font-black text-brand-navy">특허 균주 3종</h2><p class="mt-4 text-sm leading-7 text-slate-600">건강한 한국 여성에서 유래한 MG242, MG901, MG989 균주를 제품 컨셉의 중심에 둡니다.</p></article>
      <article class="border border-slate-200 bg-white p-7"><h2 class="text-xl font-black text-brand-navy">대표 제품 성과</h2><p class="mt-4 text-sm leading-7 text-slate-600">비너스 유산균은 7년간 누적 출고 100만개 이상, 월 2만 박스 이상 판매 흐름을 기록했습니다.</p></article>
      <article class="border border-slate-200 bg-white p-7"><h2 class="text-xl font-black text-brand-navy">부원료 설계</h2><p class="mt-4 text-sm leading-7 text-slate-600">스틱 제품은 히알루론산, 콜라겐, 비타민E, 이노시톨을 함께 담아 피부 컨디션까지 고려합니다.</p></article>
    </div>
  </section>

  <CTASection />
</BaseLayout>
