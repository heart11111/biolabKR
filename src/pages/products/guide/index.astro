---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import CTASection from "@/components/CTASection.astro";
import { articles } from "@/data/articles";
import { withBase } from "@/lib/path";
---

<BaseLayout title="제품 선택 가이드" description="비오랩 제품 선택과 사용 기준을 제품소개 안에서 함께 안내합니다.">
  <SubHero title="제품 선택 가이드" description="여성 유산균, 이너케어, 키즈 제품을 고를 때 확인하면 좋은 기준을 정리했습니다." />
  <Breadcrumb parent={{ label: "제품소개", href: "/products/" }} current="제품 선택 가이드" />

  <section class="section-band bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="PRODUCT COLUMN" title="제품 선택 칼럼" description="제품 상세 정보와 함께 참고할 수 있는 정보성 콘텐츠입니다." />
      <div class="grid gap-6 md:grid-cols-3">
        {articles.map((article) => (
          <a class="group overflow-hidden border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-corporate" href={withBase(`/products/guide/${article.slug}/`)}>
            <img class="h-52 w-full bg-slate-50 object-contain" src={withBase(article.image)} alt={article.title} loading="lazy" decoding="async" />
            <div class="p-7">
              <div class="flex flex-wrap items-center gap-3 text-sm">
                <span class="bg-brand-mint px-3 py-1 font-bold text-brand-green">{article.category}</span>
                <time class="text-slate-500">{article.date}</time>
              </div>
              <h2 class="mt-5 text-xl font-black leading-8 text-brand-navy">{article.title}</h2>
              <p class="mt-4 text-sm leading-7 text-slate-600">{article.excerpt}</p>
              <span class="mt-6 inline-flex text-sm font-extrabold text-brand-blue">
                자세히 보기 <span class="ml-2 transition group-hover:translate-x-1" aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
