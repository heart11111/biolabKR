---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import CTASection from "@/components/CTASection.astro";
import { articles, type Article } from "@/data/articles";
import { withBase } from "@/lib/path";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

type Props = {
  article: Article;
};

const { article } = Astro.props;
---

<BaseLayout title={article.title} description={article.excerpt} image={article.image}>
  <SubHero title={article.category} description={article.excerpt} image={article.image} imagePosition="54% 48%" visualWord="GUIDE" />
  <Breadcrumb parent={{ label: "제품소개", href: "/products/" }} current={article.title} />

  <article class="section-band bg-white">
    <div class="container-page max-w-4xl">
      <div class="mb-8 flex flex-wrap items-center gap-3 text-sm">
        <span class="bg-brand-mint px-3 py-1 font-bold text-brand-green">{article.category}</span>
        <time class="text-slate-500">{article.date}</time>
      </div>
      <h1 class="text-4xl font-black leading-tight text-brand-navy">{article.title}</h1>
      <img class="my-10 h-[380px] w-full bg-slate-50 object-contain shadow-corporate" src={withBase(article.image)} alt={article.title} />
      <div class="space-y-6 text-lg leading-9 text-slate-700">
        {article.content.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <p class="mt-10 border-t border-slate-200 pt-6 text-sm leading-7 text-slate-500">
        본 콘텐츠는 제품 선택에 참고할 수 있는 일반 정보이며, 질병의 진단이나 치료를 대신하지 않습니다.
      </p>
      <a class="mt-8 inline-flex border border-brand-blue px-5 py-3 text-sm font-bold text-brand-blue" href={withBase("/products/guide/")}>
        목록으로 돌아가기
      </a>
    </div>
  </article>

  <CTASection />
</BaseLayout>
