---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import CTASection from "@/components/CTASection.astro";
import { products, type Product } from "@/data/products";
import { withBase } from "@/lib/path";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

type Props = {
  product: Product;
};

const { product } = Astro.props;
---

<BaseLayout title={product.name} description={product.summary} image={product.image}>
  <SubHero title={product.name} description={product.tagline} />
  <Breadcrumb current={product.name} />

  <section class="section-band bg-white">
    <div class="container-page grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <img class="h-[480px] w-full bg-slate-50 object-contain shadow-corporate" src={withBase(product.image)} alt={product.name} />
      <div>
        <span class="bg-brand-mint px-4 py-2 text-sm font-bold text-brand-green">{product.category}</span>
        <h1 class="mt-6 text-4xl font-black text-brand-navy">{product.name}</h1>
        <p class="mt-2 text-lg font-semibold text-slate-500">{product.englishName}</p>
        <p class="mt-6 text-base leading-8 text-slate-700">{product.detail}</p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div class="bg-slate-50 p-5">
            <strong class="text-brand-navy">섭취/사용 방법</strong>
            <p class="mt-3 text-sm leading-7 text-slate-600">{product.intake}</p>
          </div>
          <div class="bg-slate-50 p-5">
            <strong class="text-brand-navy">인증/관리 정보</strong>
            <ul class="mt-3 space-y-2 text-sm text-slate-600">
              {product.certifications.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-band bg-slate-50">
    <div class="container-page grid gap-8 lg:grid-cols-2">
      <div>
        <h2 class="text-2xl font-black text-brand-navy">주요 성분</h2>
        <div class="mt-6 flex flex-wrap gap-2">
          {product.ingredients.map((item) => <span class="bg-white px-4 py-2 text-sm font-semibold text-slate-700">{item}</span>)}
        </div>
      </div>
      <div>
        <h2 class="text-2xl font-black text-brand-navy">제품 특징</h2>
        <ul class="mt-6 space-y-3">
          {product.features.map((item) => (
            <li class="flex gap-3 bg-white p-4 text-slate-700">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-green"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
