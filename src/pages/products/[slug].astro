---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubHero from "@/components/SubHero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import CTASection from "@/components/CTASection.astro";
import { products, type Product } from "@/data/products";
import { withBase } from "@/lib/path";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

type Props = {
  product: Product;
};

const { product } = Astro.props;
const qualityImage = withBase("/images/ingredients/ingredient-research-lab.jpg");
---

<BaseLayout title={product.name} description={product.summary} image={product.image}>
  <SubHero title={product.name} description={product.tagline} image={product.image} imagePosition="50% 48%" visualWord="iHEAL" />
  <Breadcrumb parent={{ label: "제품소개", href: "/products/" }} current={product.name} />

  <section class="section-band bg-white">
    <div class="container-page">
      <nav class="mb-16 grid overflow-hidden border border-slate-200 bg-white text-center text-sm font-extrabold text-slate-700 md:grid-cols-3 lg:grid-cols-6" aria-label="제품 상세 메뉴">
        {products.map((item) => (
          <a
            class:list={[
              "border-b border-slate-200 px-4 py-4 transition hover:bg-brand-mint hover:text-brand-green md:border-r lg:border-b-0",
              item.slug === product.slug ? "bg-brand-green text-white hover:bg-brand-green hover:text-white" : "bg-white",
              item.slug === products[products.length - 1].slug ? "md:border-r-0" : ""
            ]}
            href={withBase(`/products/${item.slug}/`)}
          >
            {item.name.replace("아이힐 ", "")}
          </a>
        ))}
      </nav>

      <div class="grid gap-14 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
        <figure>
          <div class="border border-slate-200 bg-slate-50 p-6">
            <img class="mx-auto h-[420px] w-full object-contain" src={withBase(product.image)} alt={product.name} />
          </div>
          <figcaption class="mt-5 text-center text-sm font-semibold text-slate-600">
            판매원: 비오랩 / 브랜드: {product.englishName}
          </figcaption>
        </figure>

        <div>
          <span class="text-sm font-black tracking-[0.26em] text-brand-green">{product.category}</span>
          <h1 class="mt-4 text-4xl font-black leading-tight text-brand-navy">{product.name}</h1>
          <p class="mt-3 text-xl font-semibold text-brand-green">{product.tagline}</p>
          <div class="mt-8 border-t border-slate-200 pt-8">
            <p class="text-base leading-8 text-slate-700">{product.detail}</p>
            <ul class="mt-8 space-y-4">
              {product.features.map((item) => (
                <li class="flex gap-4 text-base leading-7 text-slate-700">
                  <span class="mt-3 h-1.5 w-1.5 shrink-0 bg-brand-green"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-9">
            <a class="inline-flex bg-brand-green px-7 py-4 text-sm font-extrabold text-white transition hover:bg-brand-navy" href={withBase("/support/contact/")}>
              제품 문의하기
            </a>
          </div>
        </div>
      </div>

      <div class="mt-20 border-t-2 border-slate-900 pt-10">
        <div class="grid overflow-hidden border border-slate-200 bg-[#f6fbf9] lg:grid-cols-[0.34fr_0.66fr]">
          <div class="min-h-[150px] bg-cover bg-center" style={`background-image: url('${qualityImage}')`}></div>
          <div class="flex flex-col justify-center px-8 py-8 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="text-sm font-black tracking-[0.24em] text-brand-green">QUALITY INFORMATION</p>
              <p class="mt-3 text-2xl font-black leading-tight text-brand-navy">
                제품별 표시사항과 품질 기준에 따라 관리합니다.
              </p>
            </div>
            <div class="mt-6 flex gap-3 md:mt-0">
              <span class="border border-brand-green bg-white px-4 py-3 text-sm font-extrabold text-brand-green">원료 관리</span>
              <span class="border border-brand-green bg-white px-4 py-3 text-sm font-extrabold text-brand-green">품질 기준</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-band bg-slate-50">
    <div class="container-page">
      <div class="grid gap-8 lg:grid-cols-2">
        <div class="border border-slate-200 bg-white p-8">
          <h2 class="text-2xl font-black text-brand-navy">주요 성분</h2>
          <div class="mt-6 flex flex-wrap gap-2">
            {product.ingredients.map((item) => <span class="bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700">{item}</span>)}
          </div>
        </div>
        <div class="border border-slate-200 bg-white p-8">
          <h2 class="text-2xl font-black text-brand-navy">섭취/사용 방법</h2>
          <p class="mt-6 text-base leading-8 text-slate-700">{product.intake}</p>
        </div>
      </div>

      <div class="mt-8 border border-slate-200 bg-white p-8">
        <h2 class="text-2xl font-black text-brand-navy">인증/관리 정보</h2>
        <ul class="mt-6 grid gap-3 md:grid-cols-2">
          {product.certifications.map((item) => (
            <li class="flex gap-3 bg-slate-50 p-4 text-slate-700">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 bg-brand-green"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
